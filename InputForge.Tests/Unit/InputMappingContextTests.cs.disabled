using FluentAssertions;
using Godot;

namespace InputForge.Tests.Unit;

[Collection("InputForge")]
public class InputMappingContextTests(InputForgeTestFixture fixture)
{
    [Fact]
    public void Equality_TwoContextsWithSameName_AreEqual()
    {
        var a = new InputMappingContext { ContextName = "Gameplay" };
        var b = new InputMappingContext { ContextName = "Gameplay" };

        (a == b).Should().BeTrue();
        a.Equals(b).Should().BeTrue();
    }

    [Fact]
    public void Equality_IsCaseInsensitive()
    {
        var a = new InputMappingContext { ContextName = "Gameplay" };
        var b = new InputMappingContext { ContextName = "GAMEPLAY" };

        (a == b).Should().BeTrue();
    }

    [Fact]
    public void Equality_DifferentNames_AreNotEqual()
    {
        var a = new InputMappingContext { ContextName = "Gameplay" };
        var b = new InputMappingContext { ContextName = "Menu" };

        (a == b).Should().BeFalse();
        (a != b).Should().BeTrue();
    }

    [Fact]
    public void Equality_NullComparison_BehavesLikeReferenceEquality()
    {
        InputMappingContext a = null;
        InputMappingContext b = null;
        var c = new InputMappingContext { ContextName = "Gameplay" };

        (a == b).Should().BeTrue("both null should be equal");
        (a == c).Should().BeFalse();
        (c == a).Should().BeFalse();
    }

    [Fact]
    public void BindAction_InvokesBoolCallback_WithCorrectValue()
    {
        var ctx = new InputMappingContext();
        var action = new InputAction { ActionName = "Jump" };
        bool? received = null;
        ctx.BindAction(action, (bool v) => received = v);

        ctx.PushAction(action, new Vector3(1f, 0f, 0f), null);

        received.Should().BeTrue();
    }

    [Fact]
    public void BindAction_InvokesVector2Callback_WithXYComponents()
    {
        var ctx = new InputMappingContext();
        var action = new InputAction { ActionName = "Move" };
        Vector2? received = null;
        ctx.BindAction(action, (Vector2 v) => received = v);

        ctx.PushAction(action, new Vector3(0.3f, -0.7f, 0f), null);

        received.Should().Be(new Vector2(0.3f, -0.7f));
    }

    [Fact]
    public void UnbindAction_StopsReceivingCallbacks()
    {
        var ctx = new InputMappingContext();
        var action = new InputAction { ActionName = "Jump" };
        int callCount = 0;
        Action<bool> callback = _ => callCount++;

        ctx.BindAction(action, callback);
        ctx.PushAction(action, new Vector3(1f, 0f, 0f), null);
        ctx.UnbindAction(action, callback);
        ctx.PushAction(action, new Vector3(1f, 0f, 0f), null);

        callCount.Should().Be(1);
    }

    [Fact]
    public void PushAction_DoesNothing_WhenNoSubscribersForAction()
    {
        var ctx = new InputMappingContext();
        var action = new InputAction { ActionName = "Unbound" };

        // Should not throw even though nothing is registered.
        var act = () => ctx.PushAction(action, Vector3.Zero, null);

        act.Should().NotThrow();
    }

    [Fact]
    public void PushAction_MultipleSubscribers_AllReceiveTheValue()
    {
        var ctx = new InputMappingContext();
        var action = new InputAction { ActionName = "Jump" };
        int callsA = 0, callsB = 0;
        ctx.BindAction(action, (bool _) => callsA++);
        ctx.BindAction(action, (bool _) => callsB++);

        ctx.PushAction(action, new Vector3(1f, 0f, 0f), null);

        callsA.Should().Be(1);
        callsB.Should().Be(1);
    }
}
